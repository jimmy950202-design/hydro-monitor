<script>
setInterval(() => {

let power = Math.floor(100 + Math.random()*50);
let current = (2 + Math.random()).toFixed(2);
let energy = Math.floor(300 + Math.random()*50);

let voltage = (12 + Math.random()).toFixed(2);
let capacity = Math.floor(20 + Math.random()*80);

let runtime = (5 + Math.random()).toFixed(1);
let usage = Math.floor(30 + Math.random()*20);

document.getElementById("power").innerHTML = power + " W";
document.getElementById("current").innerHTML = current;
document.getElementById("energy").innerHTML = energy;

document.getElementById("voltage").innerHTML = voltage;
document.getElementById("capacity").innerHTML = capacity;

document.getElementById("runtime").innerHTML = runtime;
document.getElementById("usage").innerHTML = usage;

document.getElementById("batteryFill").style.width = capacity + "%";

},2000);
</script>
